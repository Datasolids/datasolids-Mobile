# Copy to .env.development / .env.staging / .env.production and fill in.
# These are loaded by flutter_dotenv as a runtime fallback. The preferred
# pattern is compile-time injection via --dart-define-from-file=...
# (see scripts/run.sh and the Makefile).

# Backend
API_BASE_URL=http://localhost:8000

# Sentry — production only
SENTRY_DSN=

# Firebase — push notifications
# (also set up android/app/google-services.json and
# ios/Runner/GoogleService-Info.plist — do NOT commit those.)

# Posthog / analytics (optional)
ANALYTICS_KEY=
